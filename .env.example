# Address that receives x402 payments (your Base mainnet wallet)
PAY_TO_ADDRESS=

# Coinbase CDP API key — required by the production (mainnet) facilitator.
# Create one at https://portal.cdp.coinbase.com/ (Secret API Key).
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# Base mainnet RPC used to read live gas data
BASE_MAINNET_RPC_URL=https://mainnet.base.org

PORT=4021

# --- Buyer / client (src/buyer.js) ---
# Funded Base mainnet private key (holds USDC) used to sign x402 payments.
# Never commit a real value.
BUYER_PRIVATE_KEY=
# Endpoint the buyer pays. Defaults to the live deployment if unset.
TARGET_URL=https://base-gas-x402-production.up.railway.app/gas
